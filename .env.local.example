# Copie este arquivo para .env.local e preencha com suas credenciais
# Veja CONFIGURACAO.md para instruções detalhadas

# ── Google Service Account ──────────────────────────────────────────────────
# Email da Service Account (ex: orcamento@meu-projeto.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Chave privada da Service Account (cole o conteúdo do campo "private_key" do JSON)
# Mantenha as quebras de linha como \n
GOOGLE_PRIVATE_KEY=

# ── Google Sheets ────────────────────────────────────────────────────────────
# ID da planilha do Google Sheets (parte da URL: spreadsheets/d/[ID]/edit)
GOOGLE_SPREADSHEET_ID=
